    <!-- 04 · HARD SKILLS -->
    <section class="screen" id="hardskills">
      <div class="card">
        <h2 class="section-title">HARD SKILLS</h2>
        <ul class="skill-list">
          <li><span class="skill-bar" data-pct="92">HTML / CSS</span></li>
          <li><span class="skill-bar" data-pct="85">JavaScript</span></li>
          <li><span class="skill-bar" data-pct="78">React</span></li>
