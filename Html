<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Digital CV – X-MEN Edition</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
:root {
  --steel-light:  #c8d0da;
  --steel-mid:    #8a9bb0;
  --steel-dark:   #3a4556;
  --steel-deep:   #1c2433;
  --steel-edge:   #d8e0ea;
  --graphite:     #0a0c10;
  --graphite-mid: #111620;
  --graphite-card:#0e1520;
 
  /* X-Men '97 — amarillo uniforme + rojo X */
  --xm-yellow:    #f5c400;        /* amarillo uniforme clásico */
  --xm-yellow-dim:#b8920a;        /* amarillo apagado / sombra */
  --xm-yellow-glow: rgba(245,196,0,0.22);
  --xm-red:       #cc1f0e;        /* rojo X-Men */
  --xm-red-lit:   #e83318;        /* rojo encendido */
  --xm-red-glow:  rgba(204,31,14,0.30);
 
  /* aliases que el código anterior usaba */
  --amber:        var(--xm-yellow-dim);
  --amber-lit:    var(--xm-yellow);
  --amber-glow:   var(--xm-yellow-glow);
  --red-badge:    #7a1208;
  --red-edge:     var(--xm-red-lit);
 
  --border-steel: rgba(200,208,218,0.22);
  --border-glow:  rgba(245,196,0,0.45);
  --font-hud:     "Orbitron", sans-serif;
  --font-mono:    "Share Tech Mono", monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--graphite);color:var(--steel-light);font-family:var(--font-mono)}
 
/* APP */
.app{position:relative;width:100vw;height:calc(100vh - 110px);display:flex;align-items:center;justify-content:center;overflow:hidden}
 
/* FONDO */
.background-layer{position:absolute;inset:0;z-index:0;
  background:radial-gradient(ellipse 75% 55% at 50% 45%, #1a1220 0%, #0a0c10 100%)}
.grid-lines{position:absolute;inset:0;
  background-image:linear-gradient(rgba(245,196,0,0.04) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(245,196,0,0.04) 1px,transparent 1px);
  background-size:44px 44px;animation:gridPulse 7s ease-in-out infinite}
@keyframes gridPulse{0%,100%{opacity:.5}50%{opacity:1}}
.x-watermark{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-family:var(--font-hud);font-size:min(80vw,70vh);font-weight:900;
  color:rgba(204,31,14,0.06);user-select:none;letter-spacing:-.05em;
  animation:xPulse 5s ease-in-out infinite}
@keyframes xPulse{0%,100%{opacity:.7;transform:scale(1)}50%{opacity:1;transform:scale(1.015)}}
 
.hud-layer{position:absolute;inset:12px;z-index:1;pointer-events:none}
.hud-title{position:absolute;top:0;left:50%;transform:translateX(-50%);
  font-family:var(--font-hud);font-size:.68rem;letter-spacing:.28em;
  color:var(--xm-yellow);background:var(--graphite);
  padding:4px 22px;border:1px solid var(--xm-yellow-dim);
  border-radius:0 0 5px 5px;white-space:nowrap;
  text-shadow:0 0 10px var(--xm-yellow-glow)}
.corner{position:absolute;width:26px;height:26px;border-color:var(--xm-yellow-dim);border-style:solid;opacity:.8}
.corner-tl{top:0;left:0;border-width:2px 0 0 2px}
.corner-tr{top:0;right:0;border-width:2px 2px 0 0}
.corner-bl{bottom:0;left:0;border-width:0 0 2px 2px}
.corner-br{bottom:0;right:0;border-width:0 2px 2px 0}
.hud-badge{position:absolute;width:30px;height:30px;border-radius:50%;
  border:1px solid var(--xm-red);
  background:radial-gradient(circle,#1a0a08 55%,#0a0c10 100%)}
.hud-badge-tl{top:38px;left:10px}.hud-badge-tr{top:38px;right:10px}
.hud-badge-bl{bottom:10px;left:10px}.hud-badge-br{bottom:10px;right:10px}
.hud-badge::after{content:"X";position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;font-family:var(--font-hud);font-weight:900;font-size:.8rem;
  color:var(--xm-red-lit);text-shadow:0 0 6px var(--xm-red-glow)}
 
/* SCAN LINE */
.scan-line{position:absolute;top:0;left:0;right:0;height:2px;z-index:10;opacity:.4;
  background:linear-gradient(90deg,transparent,var(--xm-red-lit),var(--xm-yellow),var(--xm-red-lit),transparent);
  animation:scan 6s linear infinite}
@keyframes scan{0%{top:0%}100%{top:100%}}
 
/* SCREENS */
.content-layer{position:relative;z-index:2;width:min(480px,92vw)}
.screen{display:none}.screen.active{display:block}
 
/* DOORS */
.door-overlay{position:absolute;inset:0;z-index:50;pointer-events:none;display:flex}
.door{position:relative;width:50%;height:100%;overflow:hidden;
  transition:transform .55s cubic-bezier(.77,0,.18,1);
  background:linear-gradient(180deg,#1e2d42 0%,#253345 25%,#1a2638 55%,#1e2d42 100%)}
.door-left {transform:translateX(-100%);border-right:1px solid var(--steel-mid)}
.door-right{transform:translateX(100%); border-left: 1px solid var(--steel-mid)}
.door-lines{position:absolute;inset:0;
  background-image:
    repeating-linear-gradient(0deg,transparent,transparent 47px,rgba(200,208,218,0.07) 47px,rgba(200,208,218,0.07) 49px),
    repeating-linear-gradient(90deg,transparent,transparent 79px,rgba(200,208,218,0.05) 79px,rgba(200,208,218,0.05) 81px)}
.door-lines::before{content:"";position:absolute;inset:0;
  background:linear-gradient(90deg,rgba(200,208,218,.06) 0%,transparent 18%,transparent 82%,rgba(200,208,218,.06) 100%)}
.door-lines::after{content:"";position:absolute;inset:0;
  background:linear-gradient(160deg,rgba(200,208,218,.04) 0%,transparent 35%,rgba(200,208,218,.03) 65%,transparent 100%)}
.door-x{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-family:var(--font-hud);font-size:min(40vw,45vh);font-weight:900;
  color:rgba(200,208,218,0.06);user-select:none;line-height:1}
.door-left  .door-x{transform:translateX(30%)}
.door-right .door-x{transform:translateX(-30%)}
.door-seam{position:absolute;top:0;bottom:0;left:50%;transform:translateX(-50%);
  width:3px;opacity:0;transition:opacity .1s;
  background:linear-gradient(180deg,transparent 0%,var(--xm-yellow) 30%,var(--xm-red-lit) 50%,var(--xm-yellow) 70%,transparent 100%);
  box-shadow:0 0 10px rgba(245,196,0,.6),0 0 22px rgba(204,31,14,.4)}
.door-left::after,.door-right::after{content:"";position:absolute;top:0;bottom:0;width:4px;
  background:linear-gradient(180deg,transparent,var(--xm-yellow) 35%,var(--xm-red-lit) 50%,var(--xm-yellow) 65%,transparent);
  opacity:0;transition:opacity .2s}
.door-left::after{right:0}.door-right::after{left:0}
.door-overlay.closing .door-left,
.door-overlay.closed  .door-left {transform:translateX(0)}
.door-overlay.closing .door-right,
.door-overlay.closed  .door-right{transform:translateX(0)}
.door-overlay.closing .door-seam,
.door-overlay.closed  .door-seam{opacity:1}
.door-overlay.closing .door-left::after,
.door-overlay.closing .door-right::after,
.door-overlay.closed  .door-left::after,
.door-overlay.closed  .door-right::after{opacity:.7}
.door-overlay.opening .door-left {transform:translateX(-100%);transition:transform .5s cubic-bezier(.77,0,.18,1) .05s}
.door-overlay.opening .door-right{transform:translateX(100%); transition:transform .5s cubic-bezier(.77,0,.18,1) .05s}
.door-overlay.opening .door-seam{opacity:0;transition:opacity .15s .3s}
 
/* CARD */
.card{background:var(--graphite-card);border:1px solid rgba(245,196,0,0.18);border-radius:6px;
  padding:26px 30px 30px;text-align:center;
  box-shadow:0 0 0 1px rgba(204,31,14,.08),inset 0 0 40px rgba(0,0,0,.5),0 0 30px rgba(204,31,14,.06);
  backdrop-filter:blur(4px)}
 
/* NOMBRE */
.name{font-family:var(--font-hud);font-size:clamp(.95rem,3vw,1.35rem);font-weight:900;
  color:var(--steel-edge);letter-spacing:.1em;margin-bottom:12px;
  text-shadow:0 1px 2px rgba(0,0,0,.8)}
.codename{font-size:.78em;color:var(--amber-lit);text-shadow:0 0 8px var(--amber-glow)}
 
/* AVATAR */
.avatar-wrap{position:relative;display:inline-block;margin:8px auto 18px}
.avatar{width:110px;height:110px;border-radius:6px;border:1px solid var(--steel-mid);
  filter:grayscale(30%) contrast(1.1) brightness(.92);
  box-shadow:0 0 0 3px rgba(138,155,176,.15),0 4px 16px rgba(0,0,0,.6);display:block}
.avatar-ring{position:absolute;inset:-5px;border-radius:9px;
  border:1px solid rgba(200,208,218,.2);animation:ringPulse 3s ease-in-out infinite}
@keyframes ringPulse{0%,100%{box-shadow:0 0 0 0 rgba(200,208,218,.2)}50%{box-shadow:0 0 0 5px rgba(200,208,218,0)}}
.xbadge{position:absolute;bottom:-8px;right:-8px;width:26px;height:26px;border-radius:50%;
  background:radial-gradient(circle,var(--red-edge),var(--red-badge));
  border:1px solid #d04020;display:flex;align-items:center;justify-content:center;
  font-family:var(--font-hud);font-size:.7rem;font-weight:900;color:#f0ccc0;
  box-shadow:0 0 8px rgba(180,60,20,.5)}
 
/* SECTION TITLE */
.section-title{font-family:var(--font-hud);font-size:.9rem;letter-spacing:.2em;
  color:var(--xm-yellow);margin-bottom:12px;
  text-shadow:0 0 10px var(--xm-yellow-glow)}
 
/* BIO */
.bio{font-size:.84rem;line-height:1.65;color:var(--steel-light);max-width:340px;margin:0 auto}
.bio em{color:var(--amber-lit);font-style:normal}
 
/* SKILL BARS */
.skill-list{list-style:none;text-align:left;margin-top:8px}
.skill-list li{margin-bottom:13px}
.skill-bar{display:block;font-size:.76rem;letter-spacing:.08em;color:var(--steel-light);margin-bottom:4px;padding-left:2px}
.skill-progress{display:block;height:5px;border-radius:2px;background:rgba(200,208,218,.1);margin-top:4px;overflow:hidden}
.skill-progress-fill{height:100%;border-radius:2px;width:0;
  background:linear-gradient(90deg,var(--xm-red) 0%,var(--xm-yellow-dim) 55%,var(--xm-yellow) 100%);
  transition:width 1.1s cubic-bezier(.22,1,.36,1);
  box-shadow:0 0 8px rgba(245,196,0,.35)}
 
/* EXPERIENCIA */
.exp-block{text-align:left;margin-bottom:15px}
.exp-block h3{font-family:var(--font-hud);font-size:.7rem;color:var(--amber-lit);letter-spacing:.1em;margin-bottom:4px}
.exp-block p{font-size:.79rem;color:var(--steel-light);line-height:1.5}
.divider{border:none;border-top:1px solid var(--border-steel);margin:14px 0}
.lang-title{font-family:var(--font-hud);font-size:.7rem;letter-spacing:.15em;color:var(--steel-edge);
  margin-bottom:8px;text-shadow:0 0 6px rgba(200,208,218,.2)}
.lang-list{list-style:none;text-align:left;font-size:.81rem}
.lang-list li{margin-bottom:5px}
 
/* CONTACTO */
.contact-list{list-style:none;text-align:left;margin-top:8px}
.contact-list li{display:flex;align-items:flex-start;gap:12px;margin-bottom:16px;padding:10px 12px;
  border:1px solid var(--border-steel);border-radius:4px;
  background:rgba(200,208,218,.03)}
.contact-icon{font-size:1.1rem;line-height:1.4;flex-shrink:0;margin-top:1px}
.contact-info{display:flex;flex-direction:column;gap:2px}
.contact-label{font-family:var(--font-hud);font-size:.58rem;letter-spacing:.2em;color:var(--steel-mid)}
.contact-value{font-size:.83rem;color:var(--steel-edge);word-break:break-all}
.contact-value a{color:var(--amber-lit);text-decoration:none}
.contact-value a:hover{text-decoration:underline}
 
/* NAV — 5 botones */
nav.menu{position:fixed;bottom:0;left:0;right:0;height:110px;display:flex;align-items:center;
  justify-content:center;gap:7px;padding:10px 10px;
  background:linear-gradient(0deg,rgba(10,12,18,.98) 0%,transparent 100%);z-index:100}
.nav-btn{position:relative;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:2px;width:clamp(62px,18vw,118px);height:70px;
  background:linear-gradient(160deg,#1a2638,#111a28);
  border:1px solid var(--border-steel);border-radius:5px;
  color:var(--steel-mid);font-family:var(--font-hud);font-size:.48rem;
  letter-spacing:.1em;cursor:pointer;transition:all .2s ease;
  box-shadow:0 0 8px rgba(200,208,218,.06);overflow:hidden}
.nav-btn::before{content:"";position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(200,208,218,.06),transparent 60%);opacity:0;transition:opacity .2s}
.nav-btn:hover::before,.nav-btn.active-nav::before{opacity:1}
.nav-btn:hover,.nav-btn.active-nav{border-color:var(--xm-yellow);color:var(--xm-yellow);
  box-shadow:0 0 16px rgba(245,196,0,.25),inset 0 0 8px rgba(245,196,0,.06);transform:translateY(-2px)}
.nav-icon{font-size:1rem;line-height:1}
.nav-label{text-align:center;line-height:1.4}
.xbadge-nav{position:absolute;top:4px;right:4px;width:15px;height:15px;border-radius:50%;
  background:radial-gradient(circle,var(--xm-red-lit),#7a1208);border:1px solid var(--xm-red);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-hud);font-size:.48rem;font-weight:900;color:#ffd8cc}
 
/* KEYBOARD HINT */
.keyboard-hint{position:fixed;bottom:8px;left:50%;transform:translateX(-50%);
  font-family:var(--font-mono);font-size:.58rem;
  color:rgba(245,196,0,.35);letter-spacing:.12em;white-space:nowrap;z-index:101;pointer-events:none}
  </style>
</head>
