<script>
/* ─── SONIDO DE TRANSICIÓN ─────────────────────────────────────────
   Efecto generado con Web Audio API: impacto metálico grave + chispa
   de alta frecuencia, como puertas de acero cerrándose.
 
   👉 PARA SUSTITUIRLO por un archivo de audio propio:
      1. Borra la función playTransitionSound() entera (aprox. líneas 1–40 de este bloque)
      2. Pega en su lugar:
 
         const _snd = new Audio("ruta/a/tu/sonido.mp3"); // ← pon tu URL o base64
         function playTransitionSound() {
           _snd.currentTime = 0;
           _snd.volume = 0.6;       // ajusta volumen 0–1
           _snd.play().catch(()=>{}); // catch silencia el error de autoplay
         }
 
   También puedes cambiar los parámetros numéricos de abajo para afinar el timbre.
   ─────────────────────────────────────────────────────────────────── */
let _audioCtx = null;
function getAudioCtx() {
  if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return _audioCtx;
}
 
function playTransitionSound() {
  try {
    const ctx = getAudioCtx();
    const now = ctx.currentTime;
 
    // — Capa 1: golpe metálico grave (oscilador + envolvente rápida)
    const osc1 = ctx.createOscillator();
    const gain1 = ctx.createGain();
    osc1.type = "sawtooth";
    osc1.frequency.setValueAtTime(120, now);
    osc1.frequency.exponentialRampToValueAtTime(35, now + 0.18);
    gain1.gain.setValueAtTime(0.45, now);
    gain1.gain.exponentialRampToValueAtTime(0.001, now + 0.22);
    osc1.connect(gain1); gain1.connect(ctx.destination);
    osc1.start(now); osc1.stop(now + 0.25);
 
    // — Capa 2: ruido blanco filtrado (chirrido metálico)
    const bufSize = ctx.sampleRate * 0.25;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < bufSize; i++) data[i] = (Math.random() * 2 - 1);
    const noise = ctx.createBufferSource();
    noise.buffer = buf;
    const filter = ctx.createBiquadFilter();
    filter.type = "bandpass";
    filter.frequency.value = 1800;
    filter.Q.value = 0.8;
    const gain2 = ctx.createGain();
    gain2.gain.setValueAtTime(0.18, now);
    gain2.gain.exponentialRampToValueAtTime(0.001, now + 0.25);
    noise.connect(filter); filter.connect(gain2); gain2.connect(ctx.destination);
    noise.start(now); noise.stop(now + 0.28);
 
    // — Capa 3: ping agudo de acero (breve tono alto)
    const osc2 = ctx.createOscillator();
    const gain3 = ctx.createGain();
    osc2.type = "sine";
    osc2.frequency.setValueAtTime(3200, now);
    osc2.frequency.exponentialRampToValueAtTime(900, now + 0.08);
    gain3.gain.setValueAtTime(0.12, now);
    gain3.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
    osc2.connect(gain3); gain3.connect(ctx.destination);
    osc2.start(now); osc2.stop(now + 0.12);
 
  } catch(e) { /* silencia errores de autoplay */ }
}
/* ─── FIN BLOQUE DE SONIDO ─────────────────────────────────────────── */
 
 
const order = ["softskills","about","experience","hardskills","contact"];
let currentIndex = order.indexOf("about"), isAnimating = false;
const doorOverlay = document.getElementById("doorOverlay");
const titles = {
  about:      "HOME / ABOUT ME",
  softskills: "SOFT SKILLS",
  experience: "EXPERIENCIA · EDUCACIÓN · IDIOMAS",
  hardskills: "HARD SKILLS",
  contact:    "CONTACTO"
};
 
function setActiveScreen(id) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  const t = document.getElementById(id);
  if (t) { t.classList.add("active"); animateSkillBars(t); }
  document.querySelectorAll(".nav-btn").forEach(b => b.classList.toggle("active-nav", b.dataset.screen === id));
  const h = document.querySelector(".hud-title");
  if (h) h.textContent = titles[id] || id.toUpperCase();
}
 
function showScreen(id) {
  if (isAnimating) return;
  const cur = document.querySelector(".screen.active");
  if (cur?.id === id) return;
  isAnimating = true;
  playTransitionSound();                      // ← sonido al cerrar puertas
  doorOverlay.className = "door-overlay closing";
  setTimeout(() => {
    doorOverlay.className = "door-overlay closed";
    setActiveScreen(id);
    setTimeout(() => {
      doorOverlay.className = "door-overlay opening";
      setTimeout(() => { doorOverlay.className = "door-overlay"; isAnimating = false; }, 600);
    }, 120);
  }, 560);
}
 
function animateSkillBars(section) {
  section.querySelectorAll(".skill-bar").forEach(bar => {
    if (bar.nextElementSibling?.classList.contains("skill-progress")) return;
    const pct = (bar.dataset.pct || "0") + "%";
    const w = document.createElement("div"); w.className = "skill-progress";
    const f = document.createElement("div"); f.className = "skill-progress-fill";
    w.appendChild(f); bar.insertAdjacentElement("afterend", w);
    requestAnimationFrame(() => requestAnimationFrame(() => { f.style.width = pct; }));
  });
}
 
document.querySelectorAll(".nav-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    const id = btn.dataset.screen;
    currentIndex = order.indexOf(id);
    showScreen(id);
  });
});
 
document.addEventListener("keydown", e => {
  const m = {
    ArrowLeft:  "softskills",
    ArrowUp:    "about",
    ArrowDown:  "experience",
    ArrowRight: "hardskills",
    KeyC:       "contact",
    c:          "contact"
  };
  const t = m[e.key] || m[e.code];
  if (t) { e.preventDefault(); currentIndex = order.indexOf(t); showScreen(t); }
});
 
/* Gamepad */
const gpPressed = {};
function pollGamepad() {
  try {
    const gps = navigator.getGamepads ? navigator.getGamepads() : [];
    const m = { 14:"softskills", 12:"about", 13:"experience", 15:"hardskills", 0:"contact" };
    for (const gp of gps) {
      if (!gp) continue;
      for (const [i, s] of Object.entries(m)) {
        const p = gp.buttons[i]?.pressed;
        if (p && !gpPressed[i]) showScreen(s);
        gpPressed[i] = p;
      }
    }
  } catch(e) { return; /* Gamepad bloqueado por Permissions Policy */ }
  requestAnimationFrame(pollGamepad);
}
try {
  if ("getGamepads" in navigator) requestAnimationFrame(pollGamepad);
} catch(e) { /* ignorar si el navegador bloquea el acceso */ }
 
setActiveScreen("about");
</script>
